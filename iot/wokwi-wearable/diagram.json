{
  "version": 1,
  "author": "Kelompok 5 - Device 2: Smartwatch Warga",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 20, "left": 20, "attrs": {} },
    { "type": "wokwi-slide-potentiometer", "id": "pot1", "top": -60, "left": 320, "attrs": { "value": "0.3" } },
    { "type": "wokwi-pushbutton", "id": "btn1", "top": 140, "left": 300, "attrs": { "color": "blue" } },
    { "type": "wokwi-pushbutton", "id": "btn2", "top": 200, "left": 300, "attrs": { "color": "green" } },
    { "type": "wokwi-pushbutton", "id": "btn3", "top": 260, "left": 300, "attrs": { "color": "red" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 340, "left": 20, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 340, "left": 80, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "led-red",   "top": 380, "left": 10, "attrs": { "color": "red" } },
    { "type": "wokwi-led", "id": "led-green", "top": 380, "left": 70, "attrs": { "color": "green" } }
  ],
  "connections": [
    ["esp:TX0", "$serialMonitor:RX", "", []],
    ["esp:RX0", "$serialMonitor:TX", "", []],

    ["pot1:GND", "esp:GND.1", "black", []],
    ["pot1:VCC", "esp:3V3",   "red",   []],
    ["pot1:SIG", "esp:D34",   "blue",  []],

    ["btn1:1.l", "esp:D18",   "blue",  []],
    ["btn1:2.l", "esp:GND.1", "black", []],

    ["btn2:1.l", "esp:D19",   "green", []],
    ["btn2:2.l", "esp:GND.1", "black", []],

    ["btn3:1.l", "esp:D21",   "red",   []],
    ["btn3:2.l", "esp:GND.1", "black", []],

    ["esp:D25",   "r1:1",      "orange", []],
    ["r1:2",      "led-red:A", "orange", []],
    ["led-red:C", "esp:GND.5", "black",  []],

    ["esp:D26",    "r2:1",       "lime", []],
    ["r2:2",       "led-green:A","lime",  []],
    ["led-green:C","esp:GND.6",  "black", []]
  ],
  "dependencies": {}
}
