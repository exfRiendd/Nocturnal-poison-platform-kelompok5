  {
    "id": "inject-test",
    "type": "inject",
    "z": "tab-iot-main",
    "name": "Test (klik untuk inject data)",
    "props": [
      {"p": "payload"},
      {"p": "topic", "vt": "str"}
    ],
    "repeat": "",
    "crontab": "",
    "once": false,
    "onceDelay": 0.1,
    "topic": "smartcity/environment/1/sensor",
    "payload": "{\"zone_id\":1,\"pm25\":185.5,\"pm10\":310.2,\"no2\":0.12,\"co\":4.5,\"o3\":0.01,\"temperature\":22.3,\"humidity\":92.0,\"wind_speed\":0.3,\"aqi\":312.0,\"recorded_at\":\"2026-06-14T23:00:00+07:00\",\"inversion_active\":true}",
    "payloadType": "json",
    "x": 150,
    "y": 180,
    "wires": [["parse-sensor"]]
