    "id": "mqtt-anomaly",
    "type": "mqtt in",
    "z": "tab-iot-main",
    "name": "MQTT Anomaly",
    "topic": "smartcity/environment/+/anomaly",
    "qos": "2",
    "datatype": "auto-detect",
    "broker": "cfg-mqtt",
    "nl": false,
    "rap": false,
    "rh": 0,
    "inputs": 0,
    "x": 120,
    "y": 260,
    "wires": [["parse-anomaly"]]
  },

  {
    "id": "parse-sensor",
    "type": "json",
    "z": "tab-iot-main",
    "name": "Parse JSON",
    "property": "payload",
    "action": "obj",
    "pretty": false,
    "x": 310,
    "y": 100,
    "wires": [["fn-sensor"]]
  },

  {
    "id": "parse-anomaly",
    "type": "json",
    "z": "tab-iot-main",
    "name": "Parse JSON",
    "property": "payload",
    "action": "obj",
    "pretty": false,
    "x": 310,
    "y": 260,
    "wires": [["fn-anomaly"]]
  },

  {
    "id": "fn-sensor",
    "type": "function",
    "z": "tab-iot-main",
    "name": "Siapkan data reading",
    "func": "var data = msg.payload;\n\n// ambil zone_id dari topic: smartcity/environment/{zone_id}/sensor\nvar parts = msg.topic.split('/');\ndata.zone_id = parseInt(parts[2]) || data.zone_id;\n\n// pastikan recorded_at ada\nif (!data.recorded_at) {\n    data.recorded_at = new Date().toISOString();\n}\n\nmsg.payload = data;\nmsg.headers = {'Content-Type': 'application/json'};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 510,
    "y": 100,
    "wires": [["http-reading"]]
  },

  {
    "id": "fn-anomaly",
    "type": "function",
    "z": "tab-iot-main",
    "name": "Siapkan data alert",
    "func": "var data = msg.payload;\n\nvar parts = msg.topic.split('/');\nvar zoneId = parseInt(parts[2]) || data.zone_id;\n\nmsg.payload = {\n    zone_id:    zoneId,\n    alert_type: data.alert_type || 'aqi_high',\n    severity:   data.severity   || 'high',\n    message:    data.message    || 'AQI melebihi batas aman',\n    value:      data.aqi        || null,\n    threshold:  200\n};\nmsg.headers = {'Content-Type': 'application/json'};\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 510,
    "y": 260,
    "wires": [["http-alert"]]
  },

  {
    "id": "http-reading",
    "type": "http request",
    "z": "tab-iot-main",
    "name": "POST /api/readings",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "http://php-environment:8002/api/readings",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 720,
    "y": 100,
    "wires": [["debug-reading"]]
  },

  {
    "id": "http-alert",
    "type": "http request",
    "z": "tab-iot-main",
    "name": "POST /api/alerts",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "http://php-environment:8002/api/alerts",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 720,
    "y": 260,
    "wires": [["debug-alert"]]
  },

  {
    "id": "debug-reading",
    "type": "debug",
