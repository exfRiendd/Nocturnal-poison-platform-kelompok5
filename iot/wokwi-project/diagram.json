{
  "version": 1,
  "author": "Kelompok 5 - Smart City Nocturnal Poison Trap",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-dht22", "id": "dht1", "top": -60, "left": 300, "attrs": { "humidity": "75", "temperature": "22" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 180, "left": 300, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 180, "left": 360, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "led-red", "top": 220, "left": 290, "attrs": { "color": "red" } },
    { "type": "wokwi-led", "id": "led-green", "top": 220, "left": 350, "attrs": { "color": "green" } }
  ],
  "connections": [
    ["esp:TX0", "$serialMonitor:RX", "", []],
    ["esp:RX0", "$serialMonitor:TX", "", []],

    ["esp:D4",    "dht1:SDA", "green",  ["h20", "v-60"]],
    ["esp:3V3",   "dht1:VCC", "red",    ["h40", "v-80"]],
    ["esp:GND.1", "dht1:GND", "black",  ["h30", "v-70"]],

    ["esp:D25",   "r1:1",      "orange", ["h60"]],
    ["r1:2",      "led-red:A", "orange", []],
    ["led-red:C", "esp:GND.2", "black",  ["v20", "h-200"]],

    ["esp:D26",    "r2:1",       "lime", ["h80"]],
    ["r2:2",       "led-green:A","lime",  []],
    ["led-green:C","esp:GND.3",  "black", ["v20", "h-260"]]
  ],
  "dependencies": {}
}